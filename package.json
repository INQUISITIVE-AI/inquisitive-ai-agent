{
  "name": "inquisitive-ai-agent",
  "version": "1.1.0",
  "private": true,
  "description": "INQUISITIVE AI — On-chain AI fund. Node.js off-chain brain + Chainlink Automation on-chain execution.",
  "main": "server/index.js",
  "engines": {
    "node": ">=20.11.0 <23",
    "npm": ">=10.2.0"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "jest",
    "test:contracts": "hardhat test",
    "compile": "hardhat compile",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network mainnet",
    "setup:vault": "hardhat run scripts/setupVaultV2.js --network mainnet",
    "verify:state": "hardhat run scripts/verify-state.js --network mainnet",
    "authorize:forwarder": "hardhat run scripts/authorize-forwarder.js --network mainnet",
    "server": "node server/index.js",
    "server:dev": "nodemon server/index.js",
    "dev:all": "concurrently \"npm:server:dev\" \"npm:dev\" --names backend,frontend --prefix-colors cyan,magenta",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@reown/appkit": "1.7.8",
    "@reown/appkit-adapter-wagmi": "1.7.8",
    "@tanstack/react-query": "5.59.16",
    "axios": "1.7.9",
    "better-sqlite3": "11.5.0",
    "compression": "1.7.5",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "ethers": "6.13.4",
    "express": "4.21.2",
    "express-rate-limit": "7.4.1",
    "helmet": "8.0.0",
    "next": "14.2.20",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "viem": "2.21.54",
    "wagmi": "2.13.3",
    "ws": "8.18.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "5.0.0",
    "@types/node": "20.17.9",
    "@types/react": "18.3.12",
    "@types/ws": "8.5.13",
    "concurrently": "9.1.0",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.20",
    "hardhat": "2.22.17",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "nodemon": "3.1.7",
    "prettier": "3.4.2",
    "typescript": "5.7.2"
  },
  "overrides": {
    "wagmi": "2.13.3",
    "viem": "2.21.54",
    "@wagmi/core": "2.15.2",
    "@wagmi/connectors": "5.6.3",
    "@tanstack/react-query": "5.59.16",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
