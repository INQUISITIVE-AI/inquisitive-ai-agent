# ── INQUISITIVE AI — Environment Configuration ────────────────────────────────
#
# AUTONOMOUS EXECUTION MODEL (NO PRIVATE KEY REQUIRED):
#   • Prices:     CoinGecko (free, no key) + CryptoCompare fallback (free, no key)
#   • Execution:  HYBRID KEEPER MODEL (zero cost)
#                 → PRIMARY:  cron-job.org → /api/inquisitiveAI/execute/auto (every 1 min)
#                 → BACKUP:   GitHub Actions vault-keeper.yml (every 5 min)
#                 → OPTIONAL: Chainlink Automation (register at automation.chain.link)
#   • ETH-DIRECT: vault.performUpkeep() — Uniswap V3, ETH mainnet, 27 assets
#   • BRIDGE:     vault.performUpkeep() — deBridge DLN, 13 assets (Solana/BSC/Avalanche/Optimism/TRON)
#   • stETH YIELD: 25 assets held as Lido stETH, native price tracked
#   • Portfolio:  All 65 assets tracked at NATIVE prices — no proxy disconnect
#
# SETUP STATUS (all complete):
#   ✅ 1. Vault deployed:        0xaDCFfF8770a162b63693aA84433Ef8B93A35eb52
#   ✅ 2. setPortfolio():        26 ETH-mainnet ERC-20s configured on-chain
#   ✅ 3. setPhase2Registry():   13 cross-chain deBridge DLN assets configured
#   ✅ 4. setAutomationEnabled(true) confirmed on-chain
#   ✅ 5. ETH funded to vault
#   ✅ 6. Hybrid keeper running: cron-job.org (1 min) + GitHub Actions (5 min)
#
# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Frontend
NEXT_PUBLIC_API_URL=https://your-domain.com
NEXT_PUBLIC_WS_URL=wss://your-domain.com
NEXT_PUBLIC_CHAIN_ID=1

# WalletConnect — required for MetaMask / Trust Wallet / Rainbow connect
# FREE at https://cloud.walletconnect.com (no credit card)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ── DEPLOYED CONTRACT ADDRESSES (Ethereum Mainnet) ────────────────────────────
# Vault address: the InquisitiveVaultUpdated contract
INQUISITIVE_VAULT_ADDRESS=0xaDCFfF8770a162b63693aA84433Ef8B93A35eb52
NEXT_PUBLIC_VAULT_ADDRESS=0xaDCFfF8770a162b63693aA84433Ef8B93A35eb52

# INQAI token address
INQAI_TOKEN_ADDRESS=0xB312B6E0842b6D51b15fdB19e62730815C1C7Ce5
NEXT_PUBLIC_INQAI_TOKEN_ADDRESS=0xB312B6E0842b6D51b15fdB19e62730815C1C7Ce5

# AIStrategyManager address
INQUISITIVE_STRATEGY_ADDRESS=0x8431173FA9594B43E226D907E26EF68cD6B6542D
NEXT_PUBLIC_STRATEGY_ADDRESS=0x8431173FA9594B43E226D907E26EF68cD6B6542D

# Deployer / team wallet — used for on-chain NAV reads only (read-only, no key needed)
DEPLOYER_ADDRESS=0x4e7d700f7E1c6Eeb5c9426A0297AE0765899E746

# ── RPC (free public fallbacks used automatically if not set) ─────────────────
# Optional but recommended — get free tier at https://alchemy.com or https://infura.io
MAINNET_RPC_URL=https://mainnet.infura.io/v3/your_infura_project_id

# ── VERCEL CRON SECURITY ──────────────────────────────────────────────────────
# Protects the /api/inquisitiveAI/execute/auto cron endpoint from public calls.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=generate-a-secure-random-string-here

# ── DEPLOYMENT KEY (used ONCE to deploy the vault — delete after deploying) ─────
# Set this in your LOCAL .env only. Never commit. Never add to Vercel.
# After deployment, delete this line from your .env.
# Run: npx hardhat run scripts/deploy-upgraded.js --network mainnet
# Then update INQUISITIVE_VAULT_ADDRESS above with the new vault address.
PRIVATE_KEY=

# ── GELATO RELAY (primary keyless executor — FREE, no private key required) ──
# Gelato executor nodes call vault.performUpkeep() on every Vercel Cron tick.
# NO private key anywhere — Gelato is an API credential only (revocable any time).
# Setup:
#   1. Go to https://app.gelato.network → sign in with MetaMask
#   2. Create a new Relay App → copy your API key
#   3. Add GELATO_API_KEY here (Vercel: Settings → Environment Variables)
#   4. Fund your Gelato 1Balance with a small amount of ETH for gas sponsorship
# Once set, Vercel Cron fires every 60s → auto.ts → Gelato relay → performUpkeep()
GELATO_API_KEY=your_gelato_api_key_here

# ── OPTIONAL: EXECUTOR HOT WALLET (fallback if Gelato unavailable) ────────────
# If set, Vercel Cron uses this wallet to call performUpkeep().
# CAN ONLY call performUpkeep() — cannot withdraw vault funds.
# Setup: node -e "const {Wallet}=require('ethers'); const w=Wallet.createRandom(); console.log(w.address, w.privateKey);"
# Then: send 0.01 ETH for gas, call vault.setAIExecutor(executorAddress) on Etherscan.
# DO NOT commit. Store ONLY in Vercel encrypted env vars.
EXECUTOR_PRIVATE_KEY=

# ── BRIDGE WALLETS ON DESTINATION CHAINS (deBridge DLN — 13 assets) ──────────
# Required for cross-chain execution. Each asset's ETH allocation is bridged
# to the corresponding wallet on its destination chain via deBridge DLN.
# Assets without a wallet set are held as Lido stETH until wallet is configured.
#
# Solana — receives: SOL, JUP, jitoSOL, jupSOL, MNDE, PYTH, HNT, HONEY (8 assets)
# Use a Phantom/Solflare wallet address (base58, starts with a letter/number, 32-44 chars)
PORTFOLIO_WALLET_SOLANA=7a2WzumijyGTqALmqoDZd3mvyP2aS7R4GjBdBxMUjRPk
#
# BSC — receives: BNB (as WBNB on BSC), FDUSD
# Standard 0x EVM address
PORTFOLIO_WALLET_BSC=0x4e7d700f7E1c6Eeb5c9426A0297AE0765899E746
#
# Avalanche C-Chain — receives: AVAX (as WAVAX on Avalanche)
# Standard 0x EVM address (same key as BSC if desired — different chain, no conflict)
PORTFOLIO_WALLET_AVALANCHE=0x4e7d700f7E1c6Eeb5c9426A0297AE0765899E746
#
# Optimism — receives: OP (native Optimism token)
PORTFOLIO_WALLET_OPTIMISM=0x4e7d700f7E1c6Eeb5c9426A0297AE0765899E746
#
# TRON — receives: TRX (native TRON). Must be a T-address (base58 TRON format, 34 chars, starts with T).
PORTFOLIO_WALLET_TRON=TDSkgbhuMAHChDw6kGCLJmM9v7PPMJgHJA

# ── OPTIONAL: BACKEND SERVER (for WebSocket + server-side AI) ─────────────────
BACKEND_PORT=3002
WS_PORT=3003
NODE_ENV=production
JWT_SECRET=generate-a-secure-random-256-bit-string-here

# ── OPTIONAL: NOTIFICATIONS ───────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=your_discord_webhook_for_alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── OPTIONAL: ETHERSCAN (for contract verification during deployment) ──────────
ETHERSCAN_API_KEY=your_etherscan_api_key

