# ── INQUISITIVE AI — Environment Configuration ───────────────────────────────
NODE_ENV=production
PORT=3002
LOG_LEVEL=info
RATE_LIMIT_SALT=change_me_to_32_random_bytes

# ── PUBLIC (browser-visible) FRONTEND ────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.getinqai.com
NEXT_PUBLIC_WS_URL=wss://api.getinqai.com/ws
NEXT_PUBLIC_CHAIN_ID=1
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=replace_with_reown_cloud_project_id

# ── DEPLOYED CONTRACT ADDRESSES (Ethereum Mainnet) ───────────────────────────
INQUISITIVE_VAULT_ADDRESS=0xb99dc519c4373e5017222bbd46f42a4e12a0ec25
NEXT_PUBLIC_VAULT_ADDRESS=0xb99dc519c4373e5017222bbd46f42a4e12a0ec25
INQAI_TOKEN_ADDRESS=0xB312B6E0842b6D51b15fdB19e62730815C1C7Ce5
NEXT_PUBLIC_INQAI_TOKEN=0xB312B6E0842b6D51b15fdB19e62730815C1C7Ce5
INQAI_STAKING_ADDRESS=0x46625868a36c11310fb988a69100e87519558e59
FEE_DISTRIBUTOR_ADDRESS=0x0d6aed33e80bc541904906d73ba4bfe18c730a09
REFERRAL_TRACKER_ADDRESS=0xa9a851b9659de281bfad8c5c81fe0b55aa23727a
LIQUIDITY_LAUNCHER_ADDRESS=0x617664c7dab0462c50780564f9554413c729830d
TIMELOCK_ADDRESS=0x972b7f40d1837f0b8bf003d7147de7b9fcfc601e
INSURANCE_ADDRESS=0xa0486fc0b9e4a282eca0435bae141be6982e502e
LEGACY_VAULT_ADDRESS=0x721b0c1fcf28646d6e0f608a15495f7227cb6cfb

# ── RPC ENDPOINTS ────────────────────────────────────────────────────────────
# Alchemy — https://dashboard.alchemy.com (free tier)
# NOTE: host is eth-mainnet.g.alchemy.com (the old alchemyapi.io host is deprecated)
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/replace_with_alchemy_key
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/replace_with_alchemy_key
MAINNET_WSS_URL=wss://eth-mainnet.g.alchemy.com/v2/replace_with_alchemy_key

# ── OPERATOR SIGNING KEY (server-side only) ──────────────────────────────────
# Generate with: openssl rand -hex 32
# Store in a secrets manager (Railway / Doppler / AWS SM). NEVER commit.
OPERATOR_PRIVATE_KEY=0xreplace_with_64_hex_chars
PRIVATE_KEY=

# ── CHAINLINK AUTOMATION ─────────────────────────────────────────────────────
# Register at https://automation.chain.link and paste upkeep id below.
CHAINLINK_UPKEEP_ID=0
CHAINLINK_REGISTRY_ADDRESS=0x6593c7De001fC8542bB1703532EE1E5aA0D458fD
CHAINLINK_REGISTRAR_ADDRESS=0x6B0B234fB2f380309D47A7E9391E29E9a179395a
CHAINLINK_LINK_TOKEN=0x514910771AF9Ca656af840dff83E8264EcF986CA

# ── COINGECKO ────────────────────────────────────────────────────────────────
# Free tier works. Optional pro key at https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
COINGECKO_PRO_BASE=https://pro-api.coingecko.com/api/v3

# ── COINMARKETCAP (optional tertiary fallback) ───────────────────────────────
COINMARKETCAP_API_KEY=

# ── BINANCE / COINBASE (public — no auth) ────────────────────────────────────
BINANCE_API_BASE=https://api.binance.com
BINANCE_API_BACKUP=https://api.binance.us
COINBASE_API_BASE=https://api.exchange.coinbase.com

# ── ALPHA VANTAGE (Yahoo Finance replacement) ────────────────────────────────
# Free key — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=replace_with_alpha_vantage_key

# ── WEBSOCKET AUTH ───────────────────────────────────────────────────────────
WS_API_KEY=change_me_to_32_random_bytes
WS_TICKET_TTL_SECONDS=60

# ── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL=file:./data/inquisitive.db

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://getinqai.com,https://www.getinqai.com,https://app.getinqai.com

# ── OBSERVABILITY ────────────────────────────────────────────────────────────
SENTRY_DSN=
UPTIME_ROBOT_ALERT_URL=

# ── ETHERSCAN ────────────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=

# ── RUNTIME FLAGS ────────────────────────────────────────────────────────────
AUTO_START_TRADING=false
ALLOW_OPERATOR_FALLBACK=false
OHLC_STREAM=false
