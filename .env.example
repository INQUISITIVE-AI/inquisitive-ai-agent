# ── REQUIRED FOR LAUNCH ──────────────────────────────────────────────────────

# Backend
BACKEND_PORT=3002
WS_PORT=3003
NODE_ENV=production
JWT_SECRET=generate-a-secure-random-256-bit-string-here

# Frontend
NEXT_PUBLIC_API_URL=https://your-domain.com
NEXT_PUBLIC_WS_URL=wss://your-domain.com

# Database (PostgreSQL 15)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-secure-db-password
DB_NAME=inquisitive_ai

# Live Prices — CoinMarketCap (PRIMARY, most accurate)
# Sign up FREE at https://coinmarketcap.com/api/  (10,000 calls/month free tier)
# Without this key, prices fall back to CoinGecko (also free, no key needed)
CMC_API_KEY=your_coinmarketcap_api_key_here

# Mobile Wallet QR Codes — WalletConnect Project ID
# Get a FREE Project ID at https://cloud.walletconnect.com
# Required for Trust Wallet, Rainbow, Argent, imToken, SafePal QR connections
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Contract Addresses (Ethereum Mainnet)
INQUISITIVE_VAULT_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9
INQUISITIVE_STRATEGY_ADDRESS=0xa513E6E4b8f2a923D98304ec87F64353C4D5C853
INQUISITIVE_SECURITY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
INQUISITIVE_LENDING_ADDRESS=0x9fE46736679d2D6a1F9c6513a9A3c4C6C6B6B6B6
INQUISITIVE_PROFIT_MAXIMIZER_ADDRESS=0x8b3A8f1c1c1c1c1c1c1c1c1c1c1c1c1c1c1c1c1c
INQUISITIVE_PRICE_ORACLE_ADDRESS=0x7c5A0B9A9B9B9B9B9B9B9B9B9B9B9B9B9B9B9B9B9
INQUISITIVE_COLLATERAL_MANAGER_ADDRESS=0x6d2B8A8A8A8A8A8A8A8A8A8A8A8A8A8A8A8A8A8A8

# Team & Creator Addresses (PRIVATE - Do not commit actual addresses)
CREATOR_ADDRESS=
TEAM_MEMBER_1_ADDRESS=
TEAM_MEMBER_2_ADDRESS=
TEAM_MEMBER_3_ADDRESS=

NEXT_PUBLIC_VAULT_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9
NEXT_PUBLIC_STRATEGY_ADDRESS=0xa513E6E4b8f2a923D98304ec87F64353C4D5C853
NEXT_PUBLIC_SECURITY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
NEXT_PUBLIC_AUTOMATION_ADDRESS=0x5FC8d32690cc91D4c39d9d3abcBD16989F875707

# Ethereum RPC (Infura / Alchemy / QuickNode)
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_infura_project_id
NEXT_PUBLIC_CHAIN_ID=1

# Email Notifications (optional — uses nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@inquisitive.ai

# Monitoring (optional)
SENTRY_DSN=your_sentry_dsn
DISCORD_WEBHOOK_URL=your_discord_webhook_for_alerts

# ── OPTIONAL INTEGRATIONS ─────────────────────────────────────────────────────

# Network Configuration
NETWORK_ID=31337
RPC_URL=http://localhost:8545
PRIVATE_KEY=your_private_key_here

# zkSync Configuration
ZKSYNC_URL=https://mainnet.era.zksync.io
ZKSYNC_TESTNET_URL=https://testnet.era.zksync.dev
